// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  OWNER
  SYSTEM_ADMIN
}

enum BusinessType {
  RETAIL
  TRANSPORT
  SERVICES
  OTHER
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BusinessModule {
  id          String                  @id @default(cuid())
  name        String
  type        BusinessType            @default(OTHER)
  apiKey      String                  @unique // Store hashed or raw depending on requirements, usually hashed
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  summaries   DailyFinancialSummary[]
}

model DailyFinancialSummary {
  id            String         @id @default(cuid())
  businessId    String
  business      BusinessModule @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date          DateTime       @db.Date
  totalRevenue  Decimal        @db.Decimal(12, 2)
  totalExpenses Decimal        @db.Decimal(12, 2)
  netProfit     Decimal        @db.Decimal(12, 2)
  metadata      Json?          // For business-specific extra stats

  @@unique([businessId, date]) // Ensures one summary per business per day, allowing upsert
}
